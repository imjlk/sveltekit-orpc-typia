	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260628.1",
		"typescript": "7.0.1-rc",
		"wrangler": "^4.105.0"
	},
	"dependencies": {
		"@repo/auth-hasher-contracts": "workspace:*"
	}
}
