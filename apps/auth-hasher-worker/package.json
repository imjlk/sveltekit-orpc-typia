{
	"name": "auth-hasher-worker",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"scripts": {
		"build:kernel": "bun ./scripts/build-kernel.ts",
		"dev": "wrangler dev --local",
		"deploy": "wrangler deploy",
		"check": "bun run build:kernel && bun ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && cargo check --manifest-path Cargo.toml --target wasm32-unknown-unknown",
