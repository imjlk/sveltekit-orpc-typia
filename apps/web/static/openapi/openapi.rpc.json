            "type": "string"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CategoryTreeNode"
            }
          }
        },
        "required": [
          "id",
          "name",
          "parentId",
          "createdAt",
          "children"
        ]
      }
    }
