{
  "name": "sveltekit-orpc-typia",
  "private": true,
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:web:solo": "bun scripts/dev-web.ts",
    "dev:web:cf": "bun run --cwd apps/web dev:cf",
    "dev": "bun scripts/dev.ts",
    "build": "bun run --cwd packages/shared build && bun run --cwd apps/web build",
    "check": "bun run --cwd packages/shared build && bunx tsc -p apps/api/tsconfig.json --noEmit && bun run --cwd apps/web check",
    "test:e2e": "bun run --cwd apps/web test:e2e",
    "test:e2e:solo": "bun run --cwd apps/web test:e2e:solo"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  },
  "module": "index.ts",
  "type": "module"
}
