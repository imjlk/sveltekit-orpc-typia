{
  "name": "@repo/shared",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./modules/*/types": {
      "types": "./dist/modules/*/types.d.ts",
      "import": "./dist/modules/*/types.js"
    },
    "./modules/*/schema": {
      "types": "./dist/modules/*/schema.d.ts",
      "import": "./dist/modules/*/schema.js"
    },
    "./modules/*/contract": {
      "types": "./dist/modules/*/contract.d.ts",
      "import": "./dist/modules/*/contract.js"
    },
    "./modules/*/errors": {
      "types": "./dist/modules/*/errors.d.ts",
      "import": "./dist/modules/*/errors.js"
    },
    "./contracts/*": {
      "types": "./dist/contracts/*.d.ts",
      "import": "./dist/contracts/*.js"
    },
    "./transport/*": {
      "types": "./dist/transport/*.d.ts",
      "import": "./dist/transport/*.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@ttsc/unplugin": "0.16.6",
    "@types/bun": "latest",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@orpc/contract": "^1.14.6",
    "@orpc/server": "^1.14.6",
    "@repo/db": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "typia": "13.0.0-dev.20260626.1"
  }
}
