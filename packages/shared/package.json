{
  "name": "@repo/shared",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./modules/post/types": {
      "types": "./dist/modules/post/types.d.ts",
      "import": "./dist/modules/post/types.js"
    },
    "./modules/post/schema": {
      "types": "./dist/modules/post/schema.d.ts",
      "import": "./dist/modules/post/schema.js"
    },
    "./modules/post/contract": {
      "types": "./dist/modules/post/contract.d.ts",
      "import": "./dist/modules/post/contract.js"
    },
    "./modules/post/errors": {
      "types": "./dist/modules/post/errors.d.ts",
      "import": "./dist/modules/post/errors.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@kennethwkz/unplugin-typia": "^2.6.7",
    "@types/bun": "latest",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@standard-schema/spec": "^1.1.0",
    "typia": "^11.0.3"
  }
}
